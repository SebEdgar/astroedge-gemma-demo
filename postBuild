#!/bin/bash
set -eux

# Pulisci cache esistente
pip cache purge

# Installa Rust
curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
source "$HOME/.cargo/env"

# Installa transformers 5.5.0 SENZA cache
pip install --no-cache-dir transformers==5.5.0

# Pulisci tutto di nuovo
pip cache purge
cargo clean --manifest-path "$HOME/.cargo" 2>/dev/null || true
rm -rf ~/.rustup/toolchains/*/share/doc ~/.cargo/registry/cache/*

# Rimuovi file temporanei
rm -rf /tmp/*