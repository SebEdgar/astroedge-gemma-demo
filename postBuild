#!/bin/bash

# Aggiorna le librerie core per Gemma 4
pip install --no-cache-dir --upgrade \
    "transformers>=4.45.0" \
    "accelerate>=0.30.0" \
    "huggingface_hub" \
    "bitsandbytes" \
    "scipy"

# Installa i componenti per l'interfaccia interattiva
pip install --no-cache-dir \
    ipywidgets \
    voila

# Abilita le estensioni dei widget (necessario per Voila/Binder)
jupyter nbextension enable --py widgetsnbextension